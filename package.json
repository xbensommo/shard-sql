{
  "name": "@xbensommo/shard-sql",
  "version": "1.1.0",
  "description": "Standalone SQL-first data provider for adapter-driven CRUD, schema validation, relation hydration, pagination, and Firebase Data Connect integration.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./actions": {
      "types": "./dist/actions.d.ts",
      "import": "./dist/actions.js",
      "require": "./dist/actions.cjs"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js",
      "require": "./dist/adapters.cjs"
    },
    "./adapters/dataconnect": {
      "types": "./dist/adapters/dataconnect.d.ts",
      "import": "./dist/adapters/dataconnect.js",
      "require": "./dist/adapters/dataconnect.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs"
    },
    "./validators": {
      "types": "./dist/validators.d.ts",
      "import": "./dist/validators.js",
      "require": "./dist/validators.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist .tsbuildinfo",
    "build": "npm run clean && npx --yes tsup",
    "build:types": "npx --yes tsc -p tsconfig.build.json",
    "build:all": "npm run build && npm run build:types",
    "prepack": "npm run build:all",
    "test": "node --test tests/*.test.mjs",
    "test:ci": "npm run build:all && npm run test && node scripts/smoke-test.mjs",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "keywords": [
    "sql",
    "postgresql",
    "data-connect",
    "firebase-data-connect",
    "firebase-sql-connect",
    "adapter",
    "validation",
    "includes",
    "crud",
    "pagination"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  }
}
